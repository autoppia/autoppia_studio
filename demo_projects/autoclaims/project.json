{
  "projectId": "autoclaims",
  "name": "AutoClaims",
  "version": "0.1.0",
  "description": "Small insurance claims company demo with web UI, API docs and policy knowledge.",
  "industry": "insurance operations",
  "defaultBaseUrl": "http://127.0.0.1:8123",
  "auth": {
    "required": true,
    "kind": "demo_owner",
    "username": "owner@autoclaims.test",
    "password": "Passw0rd!",
    "instructions": "Use owner demo credentials for both the web UI and API benchmark runs."
  },
  "surfaces": [
    {
      "surfaceId": "autoclaims-web",
      "kind": "web",
      "name": "AutoClaims Web",
      "url": "/",
      "authRequired": true,
      "description": "Browser interface for searching claims, reviewing claim detail and changing claim state."
    },
    {
      "surfaceId": "autoclaims-api",
      "kind": "openapi",
      "name": "AutoClaims API",
      "url": "/openapi.json",
      "authRequired": true,
      "description": "REST API for customers, claims, notes and claim decisions."
    },
    {
      "surfaceId": "autoclaims-policy",
      "kind": "document_url",
      "name": "Claims Policy",
      "url": "/docs/claims_policy.md",
      "description": "Business policy used to decide approval, review and escalation."
    },
    {
      "surfaceId": "autoclaims-escalation",
      "kind": "document_url",
      "name": "Escalation Playbook",
      "url": "/docs/escalation_playbook.md",
      "description": "Operational rules for fraud flags and high-value claims."
    }
  ],
  "tasks": [
    {
      "taskId": "find_claim_status",
      "name": "Find claim status",
      "prompt": "Find the status and owner note for claim CLM-1001.",
      "successCriteria": "Returns the current claim status, customer name and latest note for CLM-1001.",
      "expectedSurfaces": ["api"],
      "riskClass": "read"
    },
    {
      "taskId": "approve_low_risk_claim",
      "name": "Approve low risk claim",
      "prompt": "Approve claim CLM-1001 if it satisfies the claims policy.",
      "successCriteria": "Uses policy docs to confirm eligibility and marks CLM-1001 approved.",
      "expectedSurfaces": ["api", "documents"],
      "riskClass": "write"
    },
    {
      "taskId": "escalate_flagged_claim",
      "name": "Escalate flagged claim",
      "prompt": "Review claim CLM-2002 and escalate it if the escalation playbook requires manual review.",
      "successCriteria": "Uses the escalation playbook and sets CLM-2002 to manual_review.",
      "expectedSurfaces": ["api", "documents"],
      "riskClass": "write"
    },
    {
      "taskId": "web_add_claim_note",
      "name": "Add claim note from UI",
      "prompt": "Using the web UI, add a note to claim CLM-3003 saying the customer requested a same-day callback.",
      "successCriteria": "The claim detail page shows the new callback note.",
      "expectedSurfaces": ["web"],
      "riskClass": "write"
    },
    {
      "taskId": "customer_summary",
      "name": "Customer claim summary",
      "prompt": "Create a short summary of all open claims for customer Ada Lovelace.",
      "successCriteria": "Finds Ada Lovelace, lists open claims and summarizes next actions.",
      "expectedSurfaces": ["api", "documents"],
      "riskClass": "read"
    }
  ],
  "taskDiscoveryExpectations": [
    {
      "taskId": "find_claim_status",
      "aliases": ["Find claim status", "Get claim details", "Check claim status"],
      "keywords": ["claim", "status", "CLM", "customer", "note"],
      "expectedSurfaces": ["api"],
      "minSimilarity": 0.42,
      "judge": "hybrid"
    },
    {
      "taskId": "approve_low_risk_claim",
      "aliases": ["Approve low risk claim", "Approve eligible claim", "Set claim decision"],
      "keywords": ["approve", "claim", "policy", "decision", "eligible"],
      "expectedSurfaces": ["api", "documents"],
      "minSimilarity": 0.42,
      "judge": "hybrid"
    },
    {
      "taskId": "escalate_flagged_claim",
      "aliases": ["Escalate flagged claim", "Manual review for fraud flag", "Set manual review"],
      "keywords": ["escalate", "manual", "review", "fraud", "claim"],
      "expectedSurfaces": ["api", "documents"],
      "minSimilarity": 0.42,
      "judge": "hybrid"
    },
    {
      "taskId": "web_add_claim_note",
      "aliases": ["Add claim note from UI", "Add note to claim", "Update claim note"],
      "keywords": ["add", "note", "claim", "ui", "callback"],
      "expectedSurfaces": ["web"],
      "minSimilarity": 0.42,
      "judge": "hybrid"
    },
    {
      "taskId": "customer_summary",
      "aliases": ["Customer claim summary", "Summarize customer claims", "List customer open claims"],
      "keywords": ["customer", "summary", "claims", "open", "Ada"],
      "expectedSurfaces": ["api", "documents"],
      "minSimilarity": 0.42,
      "judge": "hybrid"
    }
  ],
  "expectedSolutions": [
    {
      "taskId": "find_claim_status",
      "connectors": ["api"],
      "tools": ["autoclaims.api.searchcustomers", "autoclaims.api.getclaim"],
      "trajectories": [
        {
          "trajectoryId": "autoclaims:find_claim_status:api",
          "description": "Find the customer or claim, then read claim detail and latest note.",
          "toolCalls": [
            {"toolName": "autoclaims.api.getclaim", "arguments": {"claim_id": "CLM-1001"}}
          ],
          "source": "expected"
        }
      ],
      "skills": [
        {
          "skillId": "autoclaims:find_claim_status:skill",
          "name": "Read AutoClaims claim status",
          "description": "Read claim status, customer and latest note through the claims API.",
          "trajectoryIds": ["autoclaims:find_claim_status:api"],
          "source": "trajectory"
        }
      ],
      "agentProvider": {"runtimeKind": "model_agent", "provider": "openai"}
    },
    {
      "taskId": "approve_low_risk_claim",
      "connectors": ["api", "knowledge"],
      "tools": ["knowledge.company_docs.search", "autoclaims.api.getclaim", "autoclaims.api.setclaimdecision"],
      "trajectories": [
        {
          "trajectoryId": "autoclaims:approve_low_risk_claim:api_docs",
          "description": "Read policy, inspect claim, then approve only if policy criteria pass.",
          "toolCalls": [
            {"toolName": "knowledge.company_docs.search", "arguments": {"query": "approval policy low risk claim"}},
            {"toolName": "autoclaims.api.getclaim", "arguments": {"claim_id": "CLM-1001"}},
            {"toolName": "autoclaims.api.setclaimdecision", "arguments": {"claim_id": "CLM-1001", "decision": "approved"}}
          ],
          "source": "expected"
        }
      ],
      "skills": [
        {
          "skillId": "autoclaims:approve_low_risk_claim:skill",
          "name": "Approve low-risk AutoClaims claim",
          "description": "Use policy docs and claim API before setting approved decision.",
          "trajectoryIds": ["autoclaims:approve_low_risk_claim:api_docs"],
          "source": "hybrid"
        }
      ],
      "agentProvider": {"runtimeKind": "model_agent", "provider": "openai"}
    },
    {
      "taskId": "escalate_flagged_claim",
      "connectors": ["api", "knowledge"],
      "tools": ["knowledge.company_docs.search", "autoclaims.api.getclaim", "autoclaims.api.setclaimdecision"],
      "trajectories": [
        {
          "trajectoryId": "autoclaims:escalate_flagged_claim:api_docs",
          "description": "Read escalation rules, inspect fraud/high-value signals, then set manual_review.",
          "toolCalls": [
            {"toolName": "knowledge.company_docs.search", "arguments": {"query": "fraud flag manual review escalation"}},
            {"toolName": "autoclaims.api.getclaim", "arguments": {"claim_id": "CLM-2002"}},
            {"toolName": "autoclaims.api.setclaimdecision", "arguments": {"claim_id": "CLM-2002", "decision": "manual_review"}}
          ],
          "source": "expected"
        }
      ],
      "skills": [
        {
          "skillId": "autoclaims:escalate_flagged_claim:skill",
          "name": "Escalate AutoClaims fraud/high-value claim",
          "description": "Use escalation playbook before setting manual_review.",
          "trajectoryIds": ["autoclaims:escalate_flagged_claim:api_docs"],
          "source": "hybrid"
        }
      ],
      "agentProvider": {"runtimeKind": "model_agent", "provider": "openai"}
    },
    {
      "taskId": "web_add_claim_note",
      "connectors": ["web"],
      "tools": ["autoclaims.web.explore_workflows"],
      "trajectories": [
        {
          "trajectoryId": "autoclaims:web_add_claim_note:web",
          "description": "Open the web UI, find claim CLM-3003 and add the callback note.",
          "toolCalls": [
            {"toolName": "autoclaims.web.explore_workflows", "arguments": {"goal": "Add note to CLM-3003"}}
          ],
          "source": "expected"
        }
      ],
      "skills": [
        {
          "skillId": "autoclaims:web_add_claim_note:skill",
          "name": "Add AutoClaims note through UI",
          "description": "Browser trajectory for adding an operational note from the claim detail page.",
          "trajectoryIds": ["autoclaims:web_add_claim_note:web"],
          "source": "trajectory"
        }
      ],
      "agentProvider": {"runtimeKind": "claude_code", "provider": "anthropic"}
    },
    {
      "taskId": "customer_summary",
      "connectors": ["api", "knowledge"],
      "tools": ["knowledge.company_docs.search", "autoclaims.api.searchcustomers", "autoclaims.api.listclaims"],
      "trajectories": [
        {
          "trajectoryId": "autoclaims:customer_summary:api_docs",
          "description": "Find customer, list claims and summarize next actions grounded in policy.",
          "toolCalls": [
            {"toolName": "autoclaims.api.searchcustomers", "arguments": {"query": "Ada Lovelace"}},
            {"toolName": "autoclaims.api.listclaims", "arguments": {"customerId": "cust-ada"}},
            {"toolName": "knowledge.company_docs.search", "arguments": {"query": "claim next actions policy"}}
          ],
          "source": "expected"
        }
      ],
      "skills": [
        {
          "skillId": "autoclaims:customer_summary:skill",
          "name": "Summarize AutoClaims customer claims",
          "description": "Combine customer search, claims listing and policy context.",
          "trajectoryIds": ["autoclaims:customer_summary:api_docs"],
          "source": "hybrid"
        }
      ],
      "agentProvider": {"runtimeKind": "model_agent", "provider": "openai"}
    }
  ],
  "expectedHarvest": {
    "connectors": ["web", "api", "knowledge"],
    "minimumTaskCount": 5,
    "minimumToolCount": 5,
    "requiresKnowledge": true,
    "requiresApiTools": true,
    "requiresBrowserTasks": true
  },
  "benchmarkModes": [
    {
      "modeId": "api_only",
      "description": "Evaluate whether CompanyHarvester can build API tools and knowledge-backed API tasks without relying on browser workflows.",
      "surfaceFilter": ["api", "documents"],
      "discoveryInput": ["api", "documents"],
      "taskIds": ["find_claim_status", "approve_low_risk_claim", "escalate_flagged_claim", "customer_summary"],
      "expectedHarvest": {
        "connectors": ["api", "knowledge"],
        "minimumTaskCount": 4,
        "minimumToolCount": 4,
        "requiresKnowledge": true,
        "requiresApiTools": true,
        "requiresBrowserTasks": false
      },
      "metadata": {
        "preferredExecution": "api"
      }
    },
    {
      "modeId": "web_only",
      "description": "Evaluate browser-only task discovery and execution without API surfaces.",
      "surfaceFilter": ["web"],
      "discoveryInput": ["web"],
      "taskIds": ["web_add_claim_note"],
      "expectedHarvest": {
        "connectors": ["web"],
        "minimumTaskCount": 1,
        "minimumToolCount": 1,
        "requiresKnowledge": false,
        "requiresApiTools": false,
        "requiresBrowserTasks": true
      },
      "metadata": {
        "preferredExecution": "browser"
      }
    },
    {
      "modeId": "hybrid",
      "description": "Evaluate full-company onboarding where API should be preferred when available and web/docs remain available for workflows that need them.",
      "surfaceFilter": ["web", "api", "documents"],
      "discoveryInput": ["web", "api", "documents"],
      "taskIds": ["find_claim_status", "approve_low_risk_claim", "escalate_flagged_claim", "web_add_claim_note", "customer_summary"],
      "expectedHarvest": {
        "connectors": ["web", "api", "knowledge"],
        "minimumTaskCount": 5,
        "minimumToolCount": 5,
        "requiresKnowledge": true,
        "requiresApiTools": true,
        "requiresBrowserTasks": true
      },
      "metadata": {
        "preferredExecution": "best_available"
      }
    }
  ]
}
