# Copy to .env: cp .env.example .env
# MongoDB: local mongod or e.g. docker run -d -p 27017:27017 --name automata-mongo mongo:7

MONGO_CONNECTION_URI=mongodb://localhost:27017/automata
JWT_SECRET=YOUR_JWT_SECRET

# Fallback for legacy interactive browser sessions when the selected AgentConfig
# has no runtimeEndpoint. Prefer setting runtimeEndpoint on each agent; seeded
# local agents usually point to http://127.0.0.1:8080/runtime/agents/<id>/step.
AUTOPPIA_AGENT_BASE_URL=http://localhost:5000

# Agent task harvesting. By default Automata Cloud calls the decoupled
# ../autoppia_harvester service through the IWA /find_trayectory contract.
AUTOMATA_AGENT_HARVESTER=autoppia_harvester
AUTOMATA_AUTOPPIA_HARVESTER_ENDPOINT=http://127.0.0.1:5060

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
BROWSERBASE_API_KEY=YOUR_BROWSERBASE_API_KEY
BROWSERBASE_PROJECT_ID=YOUR_BROWSERBASE_PROJECT_ID

ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# smtp | console — console logs OTP in uvicorn logs (use for local dev without SMTP)
EMAIL_BACKEND=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_HOST_USERNAME=YOUR_EMAIL
EMAIL_HOST_PASSWORD=YOUR_EMAIL_APP_PASSWORD

# Local connector seeding, used by ../scripts/seed_connectors.py
AUTOMATA_SEED_EMAIL=demo@autoppia.com
AUTOMATA_SEED_COMPANY=Celeris

# Gmail connector, aligned with Studio's personal_email_worker config.
# Also accepts GOOGLE_OAUTH_CLIENT_ID, GOOGLE_OAUTH_CLIENT_SECRET,
# GOOGLE_OAUTH_REFRESH_TOKEN, GOOGLE_OAUTH_ACCESS_TOKEN, EMAIL_USER,
# EMAIL_HOST_USERNAME, and EMAIL_HOST_USER as fallbacks.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_ACCESS_TOKEN=
GMAIL_USER_EMAIL=
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send
GMAIL_API_VERSION=v1

# SMTP connector. Also accepts EMAIL_HOST, EMAIL_PORT, EMAIL_HOST_USERNAME,
# EMAIL_USER, EMAIL_HOST_USER, EMAIL_HOST_PASSWORD, and SMTP_PASS as fallbacks.
IMAP_SERVER=
IMAP_PORT=
SMTP_SERVER=
SMTP_PORT=
SMTP_EMAIL=
SMTP_PASSWORD=

# Telegram connector
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Holded connector
HOLDED_API_KEY=
HOLDED_WORKSPACE_ID=

# Public web / knowledge connector defaults
BOPA_BASE_URL=https://www.bopa.ad/
KNOWLEDGE_COLLECTION=celeris
KNOWLEDGE_SOURCE_URL=
